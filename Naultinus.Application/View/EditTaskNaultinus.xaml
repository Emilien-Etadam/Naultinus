<Window x:Class="Naultinus.View.EditTaskNaultinus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        Title="{x:Static properties:Strings.WindowTitleEditTaskNaultinus}" Height="450" Width="500" MinHeight="450" MinWidth="500"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

        <!-- Title -->
        <TextBlock Text="{x:Static properties:Strings.LabelNaultinusTitle}" Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="NaultinusTitleTextBox" Grid.Row="1" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- CalDAV URL -->
        <TextBlock Text="{x:Static properties:Strings.LabelCaldavServerUrl}" Grid.Row="2" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="3" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}"
                 Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Username -->
        <TextBlock Text="{x:Static properties:Strings.LabelUsername}" Grid.Row="4" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="5" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}"
                 Text="{Binding CalDAVUsername, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <TextBlock Text="{x:Static properties:Strings.LabelPassword}" Grid.Row="6" Style="{StaticResource NaultinusDialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="7" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogPasswordBox}"/>

        <!-- Task List ID -->
        <TextBlock Text="{x:Static properties:Strings.LabelTaskListId}" Grid.Row="8" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="TaskListIdTextBox" Grid.Row="9" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}"
                 Text="{Binding TaskListId, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Width="80" Margin="0,0,10,0" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click"/>
            <Button Content="{x:Static properties:Strings.ButtonSave}" Width="80" IsDefault="True" Style="{StaticResource NaultinusDialogButton}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
