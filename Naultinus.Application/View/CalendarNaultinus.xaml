<Window x:Class="Naultinus.View.CalendarNaultinus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Naultinus.Helpers"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        xmlns:converters="clr-namespace:Naultinus.Converters"
        helpers:WindowBackdrop.IsEnabled="True"
        helpers:WindowSinker.AlwaysOnBottom="True"
        ShowInTaskbar="False"
        Title="{x:Static properties:Strings.AddTabCalendarNaultinus}"
        Width="{Binding Width, Mode=TwoWay}"
        Height="{Binding Height, Mode=TwoWay}"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        Left="{Binding FenceX, Mode=TwoWay}"
        Top="{Binding FenceY, Mode=TwoWay}"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0" NonClientFrameEdges="None" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
                <ResourceDictionary Source="/View/Styles/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <helpers:BindingProxy x:Key="proxy" Data="{Binding}" />
        </ResourceDictionary>
    </Window.Resources>
    <Border x:Name="LayoutRoot" CornerRadius="0" ClipToBounds="True">
        <DockPanel>
            <Grid DockPanel.Dock="Top" x:Name="Header" Height="32" MouseLeftButtonDown="Header_MouseLeftButtonDown" IsHitTestVisible="True" Background="{DynamicResource NaultinusWindowBrush}" ColumnDefinitions="*,Auto">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static properties:Strings.MenuEdit}" Command="{Binding Path=Data.EditCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuRefresh}" Command="{Binding Path=Data.RefreshCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuDelete}" Command="{Binding Path=Data.DeleteNaultinusCommand, Source={StaticResource proxy}}" CommandParameter="{Binding Identifier}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewShortcutNaultinus}" Command="{Binding Path=Data.NewNaultinusCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewBrowseNaultinus}" Command="{Binding Path=Data.NewFolderPortalCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewTaskNaultinus}" Command="{Binding Path=Data.NewTaskNaultinusCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewCalendarNaultinus}" Command="{Binding Path=Data.NewCalendarNaultinusCommand, Source={StaticResource proxy}}" />
                        <MenuItem Header="{x:Static properties:Strings.MenuNewMailNaultinus}" Command="{Binding Path=Data.NewMailNaultinusCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuManageZimbraAccounts}" Command="{Binding Path=Data.ManageZimbraAccountsCommand, Source={StaticResource proxy}}" />
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuLayouts}" SubmenuOpened="LayoutsSubmenu_SubmenuOpened">
                            <MenuItem Header="{x:Static properties:Strings.MenuSaveCurrentLayout}" Command="{Binding Path=Data.SaveSnapshotCommand, Source={StaticResource proxy}}" />
                            <Separator />
                            <MenuItem ItemsSource="{Binding Path=Data.RecentSnapshots, Source={StaticResource proxy}}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource NaultinusMenuItemStyle}">
                                        <Setter Property="Header" Value="{Binding Name}" />
                                        <Setter Property="Command" Value="{Binding Path=Data.RestoreSnapshotCommand, Source={StaticResource proxy}}" />
                                        <Setter Property="CommandParameter" Value="{Binding Id}" />
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{x:Static properties:Strings.MenuManageLayouts}" Command="{Binding Path=Data.ManageSnapshotsCommand, Source={StaticResource proxy}}" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="{x:Static properties:Strings.MenuAbout}" Command="{Binding Path=Data.OpenAboutCommand, Source={StaticResource proxy}}" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock Grid.Column="0" Text="{Binding Name, Mode=OneWay}" Margin="8,0" Style="{StaticResource NaultinusHeaderText}"/>
                <Button Grid.Column="1" Content="🔄" ToolTip="{x:Static properties:Strings.TooltipRefresh}" Command="{Binding RefreshCommand}" CommandParameter="{Binding}"
                        Style="{StaticResource CircleButton}" Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center"/>
            </Grid>
            <Border DockPanel.Dock="Top" Background="{DynamicResource NaultinusControlBrush}" CornerRadius="0" Padding="12">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                    <!-- Row 0 : Error -->
                    <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{DynamicResource NaultinusErrorBrush}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" Grid.Row="0" Margin="0,0,0,8"/>

                    <!-- Row 1 : Navigation bar — use Grid not StackPanel -->
                    <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                        <Button Grid.Column="0" Content="&lt;" Command="{Binding PreviousDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="&gt;" Command="{Binding NextDayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding DateRangeDisplay}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource NaultinusTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="3" Content="⌂" ToolTip="{x:Static properties:Strings.TooltipToday}" Command="{Binding TodayCommand}" Style="{StaticResource CircleButton}" VerticalAlignment="Center" Margin="4,0,4,0"/>
                        <ComboBox Grid.Column="4" SelectedItem="{Binding ViewMode}" ItemsSource="{Binding ViewModes}"
                                  Width="75" Height="24" VerticalAlignment="Center"
                                  FontSize="11" Background="{DynamicResource NaultinusControlBrush}"
                                  Foreground="{DynamicResource NaultinusTextBrush}" BorderThickness="1"
                                  BorderBrush="{DynamicResource NaultinusBorderBrush}"/>
                    </Grid>

                    <!-- Row 2 : Légende des calendriers sources -->
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarLegend}" Margin="0,0,0,8"
                                  Visibility="{Binding HasCalendarLegend, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                             Fill="{Binding ColorHex, Converter={StaticResource ColorToBrushConverter}}"/>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="10" Margin="4,0,0,0"
                                               Foreground="{DynamicResource NaultinusSubtleBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Row 3 : Loading -->
                    <StackPanel Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Style="{StaticResource NaultinusProgressBar}"/>
                        <TextBlock Text="{x:Static properties:Strings.LoadingEllipsis}" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource NaultinusTextBrush}"/>
                    </StackPanel>

                    <!-- Row 3 : Event list -->
                    <ListBox Grid.Row="3" ItemsSource="{Binding Events}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource NaultinusScrollBarStyle}"/>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NaultinusListBoxItemStyle}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Day header OUTSIDE the event card -->
                                    <Border Visibility="{Binding DayHeader, Converter={StaticResource StringToVisibilityConverter}}"
                                            Margin="0,12,0,4" Padding="4,4"
                                            CornerRadius="3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource NaultinusCardHoverBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DayHeaderDisplay}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NaultinusAccentBrush}"/>
                                    </Border>
                                    <!-- Carte événement : liseré gauche = couleur du calendrier source -->
                                    <Border BorderBrush="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" BorderThickness="3,0,0,0"
                                            Padding="10,8" Margin="0,0,0,2" Background="{DynamicResource NaultinusCardBrush}" CornerRadius="0,4,4,0"
                                            x:Name="EventCard">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <TextBlock Grid.Row="0" Text="{Binding Summary, Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource NaultinusTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{Binding TimeDisplay, Mode=OneWay}" Margin="0,2,0,0" Foreground="{DynamicResource NaultinusSubtleBrush}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Text="{Binding Location}" Visibility="{Binding Location, Converter={StaticResource StringToVisibilityConverter}}" FontSize="11" Foreground="{DynamicResource NaultinusSubtleBrush}" FontStyle="Italic" Margin="0,2,0,0"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="EventCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="EventCard" Property="Background" Value="{DynamicResource NaultinusCardHoverBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Row 3 : Empty state (on top when no events) -->
                    <TextBlock Grid.Row="3" Text="{x:Static properties:Strings.EmptyNoEvents}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource NaultinusSubtleBrush}" FontStyle="Italic"
                               Visibility="{Binding HasNoEvents, Converter={StaticResource BoolToVis}}"/>

                    <!-- Row 4 : Add event button — rectangular, not CircleButton -->
                    <Button Grid.Row="4" Content="{x:Static properties:Strings.EventButtonAdd}" Command="{Binding AddEventCommand}"
                            Style="{StaticResource NaultinusActionButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
