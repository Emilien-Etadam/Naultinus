<Window x:Class="Naultinus.View.CreateMailNaultinusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        Title="{x:Static properties:Strings.WindowTitleNewMailNaultinus}" Height="520" MinHeight="520" Width="420" MinWidth="420"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Text="{x:Static properties:Strings.LabelZimbraAccount}" Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}"/>
        <ComboBox x:Name="ZimbraAccountCombo" Grid.Row="1" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogComboBox}" SelectionChanged="ZimbraAccountCombo_SelectionChanged"/>
        <TextBlock Text="{x:Static properties:Strings.LabelTitle}" Grid.Row="2" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="NaultinusTitleTextBox" Grid.Row="3" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding NaultinusTitle, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelImapHost}" Grid.Row="4" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="ImapHostTextBox" Grid.Row="5" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding ImapHost, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static properties:Strings.TooltipImapHostExample}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelUsernameEmail}" Grid.Row="6" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="7" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelPassword}" Grid.Row="8" Style="{StaticResource NaultinusDialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="9" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogPasswordBox}" PasswordChanged="PasswordBox_PasswordChanged"/>
        <Button x:Name="TestButton" Grid.Row="10" Content="{x:Static properties:Strings.ButtonTestConnectionLoadFolders}" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogButton}" Click="TestButton_Click" HorizontalAlignment="Left"/>
        <TextBlock Text="{x:Static properties:Strings.LabelFoldersToMonitor}" Grid.Row="11" Style="{StaticResource NaultinusDialogLabel}"/>
        <ListBox x:Name="FoldersListBox" Grid.Row="12" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogListBox}" SelectionMode="Multiple"/>
        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock Text="{x:Static properties:Strings.LabelDisplayColon}" VerticalAlignment="Center" Foreground="{DynamicResource NaultinusSubtleBrush}" Margin="0,0,8,0"/>
            <ComboBox x:Name="DisplayModeCombo" Width="140" Margin="0,0,10,0" Style="{StaticResource NaultinusDialogComboBox}" SelectedIndex="0">
                <ComboBoxItem Content="{x:Static properties:Strings.MailComboCountOnly}"/>
                <ComboBoxItem Content="{x:Static properties:Strings.MailComboCountAndSubjects}"/>
            </ComboBox>
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Width="80" Margin="0,0,10,0" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click"/>
            <Button x:Name="CreateButton" Content="{x:Static properties:Strings.ButtonCreate}" Width="80" IsDefault="True" Style="{StaticResource NaultinusDialogButton}" Click="CreateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
