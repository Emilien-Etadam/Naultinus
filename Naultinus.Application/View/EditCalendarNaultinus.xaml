<Window x:Class="Naultinus.View.EditCalendarNaultinus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        Title="{x:Static properties:Strings.WindowTitleEditCalendarNaultinus}" Height="320" Width="400" MinHeight="280" MinWidth="380"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
        <TextBlock Text="{x:Static properties:Strings.LabelNaultinusTitle}" Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox Grid.Row="1" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelDaysToShow}" Grid.Row="2" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox Grid.Row="3" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding DaysToShow, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelViewMode}" Grid.Row="4" Style="{StaticResource NaultinusDialogLabel}"/>
        <ComboBox x:Name="ViewModeCombo" Grid.Row="5" Margin="0,0,0,15" Style="{StaticResource NaultinusDialogComboBox}"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Width="80" Margin="0,0,10,0" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click"/>
            <Button Content="{x:Static properties:Strings.ButtonSave}" Width="80" IsDefault="True" Style="{StaticResource NaultinusDialogButton}" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
