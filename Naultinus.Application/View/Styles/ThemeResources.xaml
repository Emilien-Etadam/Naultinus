<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Jetons « VSS » : valeurs par défaut = thème sombre. ThemeWatcher recalcule tout (y compris
         les dégradés « usinés » et la variante claire) au démarrage et à chaque changement de thème. -->
    <!-- Surfaces -->
    <SolidColorBrush x:Key="NaultinusWindowBrush" Color="#1A1918"/>
    <SolidColorBrush x:Key="NaultinusControlBrush" Color="#212020"/>
    <SolidColorBrush x:Key="NaultinusCardBrush" Color="#282726"/>
    <SolidColorBrush x:Key="NaultinusSoftBrush" Color="#302F2D"/>
    <SolidColorBrush x:Key="NaultinusFieldBrush" Color="#2C2B29"/>
    <SolidColorBrush x:Key="NaultinusCardHoverBrush" Color="#0FFBF7F5"/>
    <SolidColorBrush x:Key="NaultinusHoverSubtleBrush" Color="#0FFBF7F5"/>
    <SolidColorBrush x:Key="NaultinusCardPressedBrush" Color="#302F2D"/>
    <SolidColorBrush x:Key="NaultinusHoverActiveBrush" Color="#302F2D"/>
    <SolidColorBrush x:Key="NaultinusBorderBrush" Color="#3D3B38"/>
    <!-- Texte -->
    <SolidColorBrush x:Key="NaultinusTextBrush" Color="#D8D5D0"/>
    <SolidColorBrush x:Key="NaultinusSubtleBrush" Color="#9A968F"/>
    <!-- Accent, sélection, focus -->
    <SolidColorBrush x:Key="NaultinusAccentBrush" Color="#4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusHighlightBrush" Color="#4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusHighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NaultinusSelectedBrush" Color="#2E4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusFocusBrush" Color="#734D9FEA"/>
    <!-- Sémantiques + soft -->
    <SolidColorBrush x:Key="NaultinusErrorBrush" Color="#EF8574"/>
    <SolidColorBrush x:Key="NaultinusErrorSoftBrush" Color="#24EF8574"/>
    <SolidColorBrush x:Key="NaultinusGreenBrush" Color="#83CD7F"/>
    <SolidColorBrush x:Key="NaultinusGreenSoftBrush" Color="#2483CD7F"/>
    <SolidColorBrush x:Key="NaultinusAmberBrush" Color="#D3AF2A"/>
    <SolidColorBrush x:Key="NaultinusAmberSoftBrush" Color="#21D3AF2A"/>
    <SolidColorBrush x:Key="NaultinusPurpleBrush" Color="#C793C2"/>
    <SolidColorBrush x:Key="NaultinusPurpleSoftBrush" Color="#24C793C2"/>
    <SolidColorBrush x:Key="NaultinusSecondaryButtonBorderBrush" Color="#739A968F"/>
    <SolidColorBrush x:Key="NaultinusPrimaryButtonBorderBrush" Color="#366FA4"/>
    <SolidColorBrush x:Key="NaultinusDangerBorderBrush" Color="#A75D51"/>
    <!-- Dégradés « matière usinée » (défauts sombre) -->
    <LinearGradientBrush x:Key="NaultinusPrimaryButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5FA9EC" Offset="0"/>
        <GradientStop Color="#4D9FEA" Offset="0.55"/>
        <GradientStop Color="#4792D7" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NaultinusRaisedGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#393837" Offset="0"/>
        <GradientStop Color="#262524" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NaultinusTabBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#353433" Offset="0"/>
        <GradientStop Color="#272625" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NaultinusDangerSolidBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F19182" Offset="0"/>
        <GradientStop Color="#EF8574" Offset="0.55"/>
        <GradientStop Color="#DC7A6B" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NaultinusSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2EFFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="0.5"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sélection plate « accent-soft » (kit VSS) pour toutes les listes et listes déroulantes :
         supprime le rehaut arrondi + pastille latérale du thème Fluent (forme de parenthèse absente du kit). -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource NaultinusTextBrush}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource NaultinusCardHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource NaultinusSelectedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource NaultinusTextBrush}"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource NaultinusCardHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource NaultinusSelectedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menus contextuels : surface flottante VSS (raised + border), police plus petite, lignes serrées. -->
    <Style x:Key="NaultinusContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource NaultinusCardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NaultinusBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NaultinusTextBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextElement.FontSize" Value="11"/>
        <Setter Property="TextElement.FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="2"/>
    </Style>
    <Style TargetType="ContextMenu" BasedOn="{StaticResource NaultinusContextMenuStyle}"/>

    <Style x:Key="NaultinusMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextElement.FontSize" Value="11"/>
        <Setter Property="TextElement.FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="8,4,10,4"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Foreground" Value="{DynamicResource NaultinusTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <!-- Item de menu plat façon kit VSS (survol = hover, sans rehaut arrondi Fluent). Gère icône, raccourci, flèche et sous-menu. -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="24,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource NaultinusSubtleBrush}"/>
                            <Path x:Name="Arrow" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" Data="M0,0 L4,4 L0,8 Z" Fill="{DynamicResource NaultinusSubtleBrush}" Visibility="Collapsed"/>
                            <Popup x:Name="PART_Popup" Placement="Right" HorizontalOffset="-2" AllowsTransparency="True" Focusable="False" PopupAnimation="None"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="{DynamicResource NaultinusCardBrush}" BorderBrush="{DynamicResource NaultinusBorderBrush}" BorderThickness="1" Padding="2" Margin="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.35" Direction="270"/>
                                    </Border.Effect>
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NaultinusCardHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource NaultinusSubtleBrush}"/>
                            <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="MenuItem" BasedOn="{StaticResource NaultinusMenuItemStyle}"/>

    <Style TargetType="Separator">
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="MinHeight" Value="1"/>
    </Style>
</ResourceDictionary>
