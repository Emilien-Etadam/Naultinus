<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette « VSS » (valeurs par défaut = thème sombre ; ThemeWatcher applique la variante claire au runtime). -->
    <SolidColorBrush x:Key="NaultinusWindowBrush" Color="#1A1918"/>
    <SolidColorBrush x:Key="NaultinusControlBrush" Color="#212020"/>
    <SolidColorBrush x:Key="NaultinusCardBrush" Color="#282726"/>
    <SolidColorBrush x:Key="NaultinusCardHoverBrush" Color="#302F2D"/>
    <SolidColorBrush x:Key="NaultinusCardPressedBrush" Color="#3A3937"/>
    <SolidColorBrush x:Key="NaultinusHoverSubtleBrush" Color="#282726"/>
    <SolidColorBrush x:Key="NaultinusHoverActiveBrush" Color="#3D3B38"/>
    <SolidColorBrush x:Key="NaultinusBorderBrush" Color="#3D3B38"/>
    <SolidColorBrush x:Key="NaultinusTextBrush" Color="#D8D5D0"/>
    <SolidColorBrush x:Key="NaultinusSubtleBrush" Color="#9A968F"/>
    <SolidColorBrush x:Key="NaultinusAccentBrush" Color="#4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusHighlightBrush" Color="#4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusHighlightTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NaultinusSelectedBrush" Color="#2E4D9FEA"/>
    <SolidColorBrush x:Key="NaultinusErrorBrush" Color="#EF8574"/>
    <SolidColorBrush x:Key="NaultinusGreenBrush" Color="#83CD7F"/>
    <SolidColorBrush x:Key="NaultinusAmberBrush" Color="#D3AF2A"/>
    <SolidColorBrush x:Key="NaultinusPurpleBrush" Color="#C793C2"/>

    <!-- Menus contextuels : pas de gras, police plus petite, lignes plus serrées (surcharge Fluent) -->
    <Style x:Key="NaultinusContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextElement.FontSize" Value="11"/>
        <Setter Property="TextElement.FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="2"/>
    </Style>
    <Style TargetType="ContextMenu" BasedOn="{StaticResource NaultinusContextMenuStyle}"/>

    <Style x:Key="NaultinusMenuItemStyle" TargetType="MenuItem">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextElement.FontSize" Value="11"/>
        <Setter Property="TextElement.FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="8,2,10,2"/>
        <Setter Property="MinHeight" Value="22"/>
    </Style>
    <Style TargetType="MenuItem" BasedOn="{StaticResource NaultinusMenuItemStyle}"/>

    <Style TargetType="Separator">
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="MinHeight" Value="1"/>
    </Style>
</ResourceDictionary>
