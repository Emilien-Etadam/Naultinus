<Window x:Class="Naultinus.View.RenameSnapshotInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        Title="{x:Static properties:Strings.WindowTitleRenameLayout}"
        Width="350" SizeToContent="Height"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}"
                   Text="{Binding PromptLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
        <TextBox x:Name="NameTextBox" Grid.Row="2" FontSize="14" Style="{StaticResource NaultinusDialogTextBox}" />
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click" Margin="0,0,8,0" />
            <Button Content="{x:Static properties:Strings.ButtonOk}" Style="{StaticResource NaultinusDialogButton}" Click="OkButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
