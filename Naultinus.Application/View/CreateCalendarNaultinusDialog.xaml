<Window x:Class="Naultinus.View.CreateCalendarNaultinusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        Title="{x:Static properties:Strings.WindowTitleNewCalendarNaultinus}" MinHeight="520" Height="600" MinWidth="480" Width="520"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">
        <TextBlock Text="{x:Static properties:Strings.LabelZimbraAccount}" Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}"/>
        <ComboBox x:Name="ZimbraAccountCombo" Grid.Row="1" Margin="0,0,0,10" Style="{StaticResource NaultinusDialogComboBox}" SelectionChanged="ZimbraAccountCombo_SelectionChanged"/>
        <TextBlock Text="{x:Static properties:Strings.LabelTitle}" Grid.Row="2" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="NaultinusTitleTextBox" Grid.Row="3" Margin="0,0,0,10" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding NaultinusTitle, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelCaldavBaseUrl}" Grid.Row="4" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="CalDAVUrlTextBox" Grid.Row="5" Margin="0,0,0,6" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding CalDAVUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static properties:Strings.TooltipCalDAVBaseUrlExample}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelUsername}" Grid.Row="6" Style="{StaticResource NaultinusDialogLabel}"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="7" Margin="0,0,0,6" Style="{StaticResource NaultinusDialogTextBox}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="{x:Static properties:Strings.LabelPassword}" Grid.Row="8" Style="{StaticResource NaultinusDialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="9" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogPasswordBox}" PasswordChanged="PasswordBox_PasswordChanged"/>
        <Button x:Name="LoadCalendarsButton" Grid.Row="10" Content="{x:Static properties:Strings.ButtonLoadCalendars}" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogButton}" Click="LoadCalendarsButton_Click" HorizontalAlignment="Left"/>
        <TextBlock Text="{x:Static properties:Strings.LabelCalendarsToShow}" Grid.Row="11" Style="{StaticResource NaultinusDialogLabel}"/>
        <ListBox x:Name="CalendarsListBox" Grid.Row="12" Margin="0,0,0,8" Style="{StaticResource NaultinusDialogListBox}" SelectionMode="Multiple" DisplayMemberPath="DisplayName" SelectionChanged="CalendarsListBox_SelectionChanged"/>
        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Width="80" Margin="0,0,10,0" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click"/>
            <Button x:Name="CreateButton" Content="{x:Static properties:Strings.ButtonCreate}" Width="80" IsDefault="True" Style="{StaticResource NaultinusDialogButton}" Click="CreateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
