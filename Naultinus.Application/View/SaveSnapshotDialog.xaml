<Window x:Class="Naultinus.View.SaveSnapshotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Naultinus.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Strings.WindowTitleSaveCurrentLayout}"
        Width="400"
        SizeToContent="Height"
        Background="{DynamicResource NaultinusWindowBrush}"
        TextElement.Foreground="{DynamicResource NaultinusTextBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/NaultinusStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="15" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="25" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="{x:Static properties:Strings.DialogLayoutNameLabel}" Grid.Row="0" Style="{StaticResource NaultinusDialogLabel}" />
        <TextBox x:Name="NameTextBox" Grid.Row="2" FontSize="14" Style="{StaticResource NaultinusDialogTextBox}" />
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Strings.ButtonCancel}" Style="{StaticResource NaultinusDialogButton}" Click="CancelButton_Click" Margin="0,0,10,0" />
            <Button Content="{x:Static properties:Strings.ButtonSave}" Style="{StaticResource NaultinusDialogButton}" Click="SaveButton_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
